{
  "meta": {
    "name": "clean-academic",
    "description": "Clean academic style — desaturated palette, transparent background, generous spacing",
    "version": "2.0.0"
  },
  "colors": {
    "background": "transparent",
    "surface": "#EDF2F7",
    "surface_alt": "#E2E8F0",
    "primary": "#BEE3F8",
    "secondary": "#C6F6D5",
    "accent": "#C3DAFE",
    "accent_warm": "#FEFCBF",
    "text_primary": "#1A202C",
    "text_secondary": "#4A5568",
    "text_on_primary": "#1A202C",
    "text_on_secondary": "#1A202C",
    "connector": "#4A5568",
    "connector_highlight": "#3182CE",
    "code_bg": "#F7FAFC",
    "code_text": "#1A202C",
    "border": "#CBD5E0",
    "success": "#C6F6D5",
    "warning": "#FEFCBF",
    "danger": "#FED7D7"
  },
  "semantic_roles": {
    "encoder": "primary",
    "decoder": "secondary",
    "attention": "accent_warm",
    "embedding": "accent",
    "output": "success",
    "input": "surface",
    "intermediate": "surface_alt"
  },
  "typography": {
    "heading_font": "Helvetica Neue",
    "body_font": "Helvetica Neue",
    "code_font": "Menlo",
    "label_font": "Helvetica Neue",
    "sizes": {
      "xxl": 44,
      "xl": 32,
      "lg": 24,
      "md": 18,
      "sm": 13,
      "xs": 10,
      "code": 13
    },
    "weights": {
      "title": "Bold",
      "label": "Regular",
      "annotation": "Light"
    }
  },
  "shapes": {
    "default_corner_radius": 6,
    "node_corner_radius": 6,
    "pill_corner_radius": 18,
    "stroke_width_default": 1.0,
    "stroke_width_emphasis": 2.0,
    "stroke_width_subtle": 0.5,
    "min_node_width": 180,
    "min_node_height": 56,
    "token_cell_width": 72,
    "token_cell_height": 36,
    "shadow": false,
    "shadow_blur": 0,
    "shadow_offset_x": 0,
    "shadow_offset_y": 0,
    "shadow_color": "#00000000"
  },
  "connectors": {
    "default_stroke": "#4A5568",
    "default_width": 1.5,
    "arrow_style": "FilledArrow",
    "routing": "orthogonal",
    "label_font_size": 12
  },
  "layout": {
    "canvas_width_slide": 1920,
    "canvas_height_slide": 1080,
    "canvas_width_diagram": 1400,
    "canvas_height_diagram": 1050,
    "margin": 80,
    "node_h_spacing": 70,
    "node_v_spacing": 50,
    "title_margin_top": 60,
    "content_margin_top": 130
  }
}
